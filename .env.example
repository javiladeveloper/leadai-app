# URL del backend de LeadAI (repo `leadia`). En dev apunta al localhost.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Client ID de Google (Google Cloud Console → Credenciales → OAuth 2.0, tipo Web).
# Sin esto, la app entra en MODO DEMOSTRACIÓN (sesión de demo con datos de ejemplo).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Meta App ID (público) para el SDK de Facebook / Embedded Signup de WhatsApp.
NEXT_PUBLIC_META_APP_ID=
# Config ID del Embedded Signup (WhatsApp → Configuración → Embedded Signup en el portal de Meta).
NEXT_PUBLIC_META_ES_CONFIG_ID=
